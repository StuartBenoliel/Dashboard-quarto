### COL 2 {width=30%}

```{r}

df <- data.frame(
  Année = 2025,
  Flux = 125000,
  Qualité = 0.98,
  Performance = 3.2
)

kable(
  df %>% 
    pivot_longer(
    cols = everything(),
    names_to = "variable",
    values_to = "valeur"
  ),
  format = "html",
  digits = 2,
  align = "c",
  caption = "Indicateurs de chargement"
) |>
  kable_styling(
    bootstrap_options = c("striped", "hover", "condensed"),
    full_width = FALSE,
    position = "center"
  )

```


### COL 3 {width=35%}


```{r}
df <- data.frame(
  A = c(1000, 2000),
  B = c(3000, 4000)
)

my_table_style(df, caption = "Indicateurs 2025")

```



