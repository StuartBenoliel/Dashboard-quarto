```{r}
#| include: false
library(DT)
library(duckdb)
library(ggplot2)
library(plotly)
library(dplyr)
library(tidyr)
library(knitr)
library(kableExtra)
library(sf)

#source("utils/connect_duckdb.R")

#bdd_gaia_prod <- get_conn_gaia("prod2")

my_table_style <- function(df, caption = NULL) {
  
  kable(
    df,
    format = "html",
    caption = caption,
    align = rep("c", ncol(df)),
    escape = FALSE
  ) |>
    kable_styling(
      bootstrap_options = c("striped", "condensed"),
      full_width = FALSE,
      position = "center"
    ) |>
    row_spec(0, bold = TRUE) |>
    column_spec(1:ncol(df), border_left = TRUE, border_right = TRUE)
}
# 
# resultat <- dbGetQuery(bdd_gaia_prod, "
#   SELECT 
#       *
#   FROM expertise.tableau_de_bord
# ") %>% tail(1)

resultat <- data.frame(
  nombre_adresses_actives = 35000000,
  nombre_voies_actives = 3500000
)

```

# Menu principal

## ROW 1

### COL 1 {width=25%}

::: {.rows}

::: {.row width="50%"}

```{r}
#| content: valuebox
#| title: "Adresses actives"
list(
  color = "blue",
  value = format(resultat$nombre_adresses_actives, 
                 big.mark = " ", scientific = FALSE)
)
```

:::

::: {.row width="50%"}

```{r}
#| content: valuebox
#| title: "Voies actives"
list(
  color = "green",
  value = format(resultat$nombre_voies_actives, 
                 big.mark = " ", scientific = FALSE)
)
```

